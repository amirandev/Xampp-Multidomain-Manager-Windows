<Page
    x:Class="XamppMultidomainManager.Pages.DomainsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Padding="32,32,32,16">
            <TextBlock Text="Virtual Hosts" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            <Button x:Name="AddBtn" Click="AddBtn_Click" Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE710;" FontSize="12" />
                    <TextBlock Text="Add Domain" />
                </StackPanel>
            </Button>
            <Button x:Name="RefreshBtn" Click="RefreshBtn_Click" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon x:Name="RefreshBtnIcon" Glyph="&#xE72C;" FontSize="12" />
                    <ProgressRing x:Name="RefreshBtnRing" Width="14" Height="14" IsActive="False" Visibility="Collapsed" />
                    <TextBlock x:Name="RefreshBtnLabel" Text="Refresh Config" />
                </StackPanel>
            </Button>
        </StackPanel>

        <Border x:Name="FormPanel" Grid.Row="1" Margin="32,0,32,16" Visibility="Collapsed"
                Style="{StaticResource CardStyle}" Padding="16">
            <StackPanel Spacing="12">
                <TextBlock x:Name="FormTitle" Text="Add New Domain" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                <Grid ColumnSpacing="12" RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBox Grid.Row="0" Grid.Column="0" x:Name="DomainInput" Header="Domain Name" PlaceholderText="myapp.local"
                             TextChanged="DomainInput_TextChanged" />
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="RootInput" Header="Document Root" IsReadOnly="True"
                             PlaceholderText="C:\xampp\htdocs\websites\..." />
                    <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" x:Name="AliasInput" Header="Server Alias (optional)" PlaceholderText="www.myapp.local" />
                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="SaveBtn" Click="SaveBtn_Click" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon x:Name="SaveBtnIcon" Glyph="&#xE74E;" FontSize="12" />
                                <ProgressRing x:Name="SaveBtnRing" Width="14" Height="14" IsActive="False" Visibility="Collapsed" />
                                <TextBlock x:Name="SaveBtnLabel" Text="Save" />
                            </StackPanel>
                        </Button>
                        <Button Click="CancelBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE711;" FontSize="12" />
                                <TextBlock Text="Cancel" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" Margin="32,0,32,16">
            <ItemsControl x:Name="HostsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="16">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{Binding DomainName}" FontWeight="SemiBold"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{Binding DocumentRoot}" Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>

                                <ToggleSwitch Grid.Column="1" IsOn="{Binding Enabled, Mode=TwoWay}"
                                              VerticalAlignment="Center" Toggled="ToggleSwitch_Toggled" />

                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Button Click="OpenDomainBtn_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE8A7;" FontSize="12" />
                                            <TextBlock Text="Open" />
                                        </StackPanel>
                                    </Button>
                                    <Button Click="OpenFolderBtn_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE8B7;" FontSize="12" />
                                            <TextBlock Text="Folder" />
                                        </StackPanel>
                                    </Button>
                                    <Button Click="RenameBtn_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE70F;" FontSize="12" />
                                            <TextBlock Text="Rename" />
                                        </StackPanel>
                                    </Button>
                                    <Button Click="DeleteBtn_Click">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                            <TextBlock Text="Delete" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock x:Name="EmptyState" Grid.Row="2"
                   Text="No virtual hosts configured. Click 'Add Domain' to add one."
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />
        <ProgressRing x:Name="PageLoadingRing" Grid.Row="2" IsActive="False" Visibility="Collapsed"
                      HorizontalAlignment="Center" VerticalAlignment="Center" Width="32" Height="32" />
    </Grid>
</Page>
