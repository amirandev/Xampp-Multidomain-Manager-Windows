<Page
    x:Class="XamppMultidomainManager.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Spacing="24" Padding="32">
            <TextBlock Text="Dashboard" Style="{StaticResource TitleTextBlockStyle}" />

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Apache" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse x:Name="ApacheStatusIndicator" Style="{StaticResource StatusIndicatorStyle}" />
                            <TextBlock x:Name="ApacheStatusText" Text="Checking..." VerticalAlignment="Center" />
                        </StackPanel>
                        <Button x:Name="ApacheBtn" Click="ApacheBtn_Click" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Left" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon x:Name="ApacheBtnIcon" Glyph="&#xE768;" FontSize="12" />
                                <ProgressRing x:Name="ApacheBtnRing" Width="14" Height="14" IsActive="False" Visibility="Collapsed" />
                                <TextBlock x:Name="ApacheBtnLabel" Text="Start Apache" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="MySQL" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse x:Name="MySqlStatusIndicator" Style="{StaticResource StatusIndicatorStyle}" />
                            <TextBlock x:Name="MySqlStatusText" Text="Checking..." VerticalAlignment="Center" />
                        </StackPanel>
                        <Button x:Name="MySqlBtn" Click="MySqlBtn_Click" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Left" Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon x:Name="MySqlBtnIcon" Glyph="&#xE768;" FontSize="12" />
                                <ProgressRing x:Name="MySqlBtnRing" Width="14" Height="14" IsActive="False" Visibility="Collapsed" />
                                <TextBlock x:Name="MySqlBtnLabel" Text="Start MySQL" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Domains" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                        <TextBlock x:Name="DomainCountText" Text="0" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="Registered Virtual Hosts" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Databases" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                        <TextBlock x:Name="DatabaseCountText" Text="0" Style="{StaticResource TitleTextBlockStyle}" />
                        <TextBlock Text="MySQL Databases" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Actions" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button x:Name="ApplyConfigBtn" Click="ApplyConfig_Click" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon x:Name="ApplyConfigBtnIcon" Glyph="&#xE8FB;" FontSize="12" />
                                <ProgressRing x:Name="ApplyConfigBtnRing" Width="14" Height="14" IsActive="False" Visibility="Collapsed" />
                                <TextBlock x:Name="ApplyConfigBtnLabel" Text="Apply Configuration" />
                            </StackPanel>
                        </Button>
                        <Button Click="RefreshBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="12" />
                                <TextBlock Text="Refresh Status" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock x:Name="StatusMessageText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
