<Page
    x:Class="XamppMultidomainManager.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Spacing="16" Padding="32">
            <TextBlock Text="About" Style="{StaticResource TitleTextBlockStyle}" />
            <Border Style="{StaticResource CardStyle}" MaxWidth="600">
                <StackPanel Spacing="12">
                    <TextBlock Text="Xampp Multidomain Manager" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                    <TextBlock Text="Version 1.0.0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock TextWrapping="WrapWholeWords">
                        A modern WinUI 3 application for managing XAMPP virtual hosts,
                        Apache/MySQL services, and local development domains.
                    </TextBlock>
                    <HyperlinkButton Content="GitHub" NavigateUri="https://github.com" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" MaxWidth="600">
                <StackPanel Spacing="8">
                    <TextBlock Text="Powered By" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="XROW.ASIA" FontSize="20" FontWeight="Bold" />
                    <TextBlock Text="Real Life Solutions for IT World" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <HyperlinkButton Content="amoswaper@gmail.com" NavigateUri="mailto:amoswaper@gmail.com" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
